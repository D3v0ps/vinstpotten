# Copy to .env and fill in. Do NOT commit .env.
# Vite exposes only VITE_ prefixed vars to the client bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional — set when you wire up real BankID via a provider like Signicat:
# VITE_BANKID_PROVIDER_URL=

# ──────────────────────────────────────────────────────────────────────────
# Admin payment tool — sätts som SUPABASE EDGE FUNCTION SECRETS, ej här.
# Lokal referenslista; i produktion: Supabase dashboard → Edge Functions
# → Secrets, eller `supabase secrets set KEY=value`.
# ──────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# STRIPE_SUCCESS_URL=https://vinstpotten.se/admin/betald
# STRIPE_CANCEL_URL=https://vinstpotten.se/admin/avbruten
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=Vinstpotten <noreply@vinstpotten.se>
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx
